# Printer configuration (comma-separated for multiple printers)
BAMBU_PRINTER_IP=192.168.1.100
BAMBU_PRINTER_ACCESS_CODE=12345678
BAMBU_PRINTER_SERIAL=01P00A000000000

# Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=4844

# Logging
LOG_LEVEL=INFO

# OrcaSlicer CLI API (leave empty to disable slicing)
ORCASLICER_API_URL=http://10.0.1.9:8070

# File upload limit (MB)
MAX_FILE_SIZE_MB=200
